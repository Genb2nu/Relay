{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "bash ${RELAY_PLUGIN_ROOT:-$(dirname $(dirname $0))}/hooks/scripts/pre-tool-use.sh"
      },
      {
        "matcher": "Bash",
        "command": "bash ${RELAY_PLUGIN_ROOT:-$(dirname $(dirname $0))}/hooks/scripts/phase-gate-hook.sh"
      }
    ],
    "SessionStart": [
      {
        "command": "bash ${RELAY_PLUGIN_ROOT:-$(dirname $(dirname $0))}/hooks/scripts/session-start.sh"
      }
    ]
  }
}
